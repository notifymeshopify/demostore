{% comment %}
  Renders an SVG icon for demo-store-features section.
  @param {string} icon - One of: preorder, notify, wishlist
{% endcomment %}
{%- liquid
  assign t = icon | default: 'preorder'
-%}
{%- case t -%}
  {%- when 'capture' -%}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false">
      <path d="M12 5v14M5 12h14"/>
      <circle cx="12" cy="12" r="9"/>
    </svg>
  {%- when 'chart' -%}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false">
      <path d="M4 19V5M8 19v-6M12 19V9M16 19v-4M20 19V11"/>
    </svg>
  {%- when 'notify' -%}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false">
      <path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Z"/>
      <path d="M18 8a6 6 0 1 0-12 0c0 7-3 8-3 8h18s-3-1-3-8"/>
    </svg>
  {%- when 'wishlist' -%}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false">
      <path d="M20.8 6.6a5.5 5.5 0 0 0-7.8 0L12 7.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/>
    </svg>
  {%- else -%}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false">
      <rect x="4" y="5" width="16" height="14" rx="2"/>
      <path d="M8 9h8M8 13h5"/>
      <path d="M16 17v3M14 20h4"/>
    </svg>
{%- endcase -%}
