{% comment %}
  Notify Me! Demo Homepage — all-in-one self-contained section
  ----------------------------------------------------------
  Renders the full demo homepage as a single Dawn section.
  No external snippets, no block dependencies, no preset wiring.
  Edit copy directly in this file or via the schema settings below.

  Drop this file at: theme/sections/demo-homepage.liquid
  Then update theme/templates/index.json to call only "demo-homepage".
{% endcomment %}

<style>
  /* ====== Brand tokens (scoped) ====== */
  .nm-demo {
    --nm-blue: #003BAF;
    --nm-blue-2: #2563eb;
    --nm-blue-grad-a: #003BAF;
    --nm-blue-grad-b: #6E8BFF;
    --nm-ink: #0F0F0F;
    --nm-navy: #1B1A2B;
    --nm-surface: #F3F4F6;
    --nm-paper: #FFFFFF;
    --nm-line: rgba(27,26,43,0.10);
    --nm-success: #10B981;
    --nm-danger: #EF4444;
    --nm-radius: 12px;
    --nm-radius-lg: 24px;
    --nm-shadow-1: 0 1px 2px rgba(15,15,15,.06), 0 8px 24px rgba(15,15,15,.06);
    --nm-shadow-2: 0 12px 40px rgba(0,59,175,.18);
    --nm-font-sans: 'Geist', system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --nm-font-mono: 'Geist Mono', ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    --nm-font-display: 'Geist', system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;

    font-family: var(--nm-font-sans);
    color: var(--nm-ink);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .nm-demo *, .nm-demo *::before, .nm-demo *::after { box-sizing: border-box; }
  .nm-demo a { color: inherit; }
  .nm-demo h1, .nm-demo h2, .nm-demo h3, .nm-demo h4, .nm-demo p, .nm-demo ul {
    margin: 0; padding: 0;
  }
  .nm-demo ul { list-style: none; }

  /* gradient italic on highlight word */
  .nm-grad {
    background: linear-gradient(90deg, var(--nm-blue-grad-a), var(--nm-blue-grad-b));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-style: italic;
    padding-inline-end: 0.08em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  /* Gradient brand name without italic — avoids clipping punctuation */
  .nm-grad.nm-grad--brand {
    font-style: normal;
    padding-inline-end: 0.12em;
  }
  .nm-eyebrow {
    font-family: var(--nm-font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--nm-blue);
    margin-bottom: 16px;
  }
  .nm-container { max-width: 1200px; margin: 0 auto; }

  /* ====== MERCHANT LOGOS (image strip) ====== */
  .nm-logos {
    background: #0a0a0a;
    padding: 40px 24px 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nm-logos__eyebrow {
    font-family: var(--nm-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.5);
    text-align: center;
    margin-bottom: 28px;
  }
  .nm-logos__figure {
    max-width: min(1100px, 100%);
    margin: 0 auto;
  }
  .nm-logos__img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ====== Buttons ====== */
  .nm-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    border-radius: var(--nm-radius);
    font-weight: 600; font-size: 15px;
    text-decoration: none; cursor: pointer; border: none;
    transition: transform .2s ease, background .2s ease, color .2s ease, box-shadow .2s ease;
    font-family: var(--nm-font-sans);
  }
  .nm-demo .nm-btn-primary,
  .nm-demo a.nm-btn-primary { background: var(--nm-blue) !important; color: #fff !important; }
  .nm-demo .nm-btn-primary:hover,
  .nm-demo a.nm-btn-primary:hover { background: var(--nm-blue-2) !important; transform: translateY(-1px); box-shadow: var(--nm-shadow-2); }
  .nm-demo .nm-btn-secondary,
  .nm-demo a.nm-btn-secondary { background: transparent !important; color: var(--nm-ink) !important; border: 1.5px solid var(--nm-line); }
  .nm-demo .nm-btn-secondary:hover,
  .nm-demo a.nm-btn-secondary:hover { border-color: var(--nm-blue); color: var(--nm-blue) !important; }
  .nm-demo .nm-btn-light,
  .nm-demo a.nm-btn-light { background: #fff !important; color: var(--nm-blue) !important; }
  .nm-demo .nm-btn-light:hover,
  .nm-demo a.nm-btn-light:hover { background: var(--nm-ink) !important; color: #fff !important; }

  /* ====== HERO ====== */
  .nm-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(72px, 12vw, 140px) 24px clamp(80px, 10vw, 120px);
    min-height: min(88vh, 920px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }
  .nm-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #0f0f14;
  }
  .nm-hero__bg-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .nm-hero__video {
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    object-position: center;
  }
  .nm-hero__mask {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 14, 0.72) 0%,
      rgba(10, 10, 14, 0.82) 38%,
      rgba(10, 10, 14, 0.92) 100%
    );
    pointer-events: none;
  }
  .nm-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    padding-inline: 4px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .nm-hero__content > .nm-eyebrow,
  .nm-hero__content > h1,
  .nm-hero__content > .nm-hero-sub {
    width: 100%;
    text-align: center;
  }
  .nm-hero .nm-eyebrow {
    color: rgba(191, 208, 255, 0.95);
  }
  .nm-hero h1 {
    font-family: var(--nm-font-display);
    font-weight: 500;
    font-size: clamp(40px, 5.4vw, 68px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
    color: #fff;
  }
  .nm-hero__accent {
    display: block;
    margin-top: 0.22em;
    font-weight: 500;
    font-size: clamp(22px, 3.2vw, 34px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .nm-hero-sub {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.84);
    margin-bottom: 0;
    margin-left: auto;
    margin-right: auto;
    max-width: 540px;
  }
  .nm-cta-row { display: flex; gap: 14px; flex-wrap: wrap; }
  .nm-hero .nm-cta-row {
    justify-content: center;
    margin-top: 52px;
  }
  .nm-hero .nm-btn-secondary,
  .nm-hero a.nm-btn-secondary {
    border-color: rgba(255, 255, 255, 0.42) !important;
    color: #fff !important;
    background: rgba(255, 255, 255, 0.08) !important;
  }
  .nm-hero .nm-btn-secondary:hover,
  .nm-hero a.nm-btn-secondary:hover {
    border-color: #fff !important;
    color: #fff !important;
    background: rgba(255, 255, 255, 0.16) !important;
  }
  /* ====== PRODUCT GRID ====== */
  .nm-products {
    background: var(--nm-paper);
    padding: 96px 24px;
    border-top: 1px solid var(--nm-line);
  }
  .nm-products-head { margin-bottom: 48px; max-width: 720px; }
  .nm-products-head h2 {
    font-family: var(--nm-font-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }
  .nm-products-head p { font-size: 18px; color: rgba(15,15,15,0.65); }

  .nm-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }
  .nm-card {
    background: var(--nm-paper);
    border: 1px solid var(--nm-line);
    border-radius: var(--nm-radius-lg);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    text-decoration: none;
    color: inherit;
  }
  .nm-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--nm-shadow-2);
    border-color: transparent;
  }
  .nm-card-art {
    aspect-ratio: 4 / 3;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 20px;
  }
  /* Product grid: brand colors — Back in Stock #003BAF, Preorder #5FD0A6, Wishlist #9B26F0, Low Stock #EE442E */
  .nm-art-1 { background: linear-gradient(145deg, #e8edf7 0%, #b4c4e8 100%); }
  .nm-art-2 { background: linear-gradient(145deg, #e8faf4 0%, #a8e8cf 100%); }
  .nm-art-3 { background: linear-gradient(145deg, #f3e9fc 0%, #dcb8f4 100%); }
  .nm-art-4 { background: linear-gradient(145deg, #fdecea 0%, #f5b0a0 100%); }

  .nm-widget-shot {
    width: 100%;
    max-width: 240px;
    padding: 14px 14px 16px;
    background: rgba(255, 255, 255, 0.94);
    border-radius: 14px;
    box-shadow: 0 12px 32px rgba(15, 15, 15, 0.14);
    border: 1px solid rgba(15, 15, 15, 0.06);
  }
  .nm-widget-shot__chrome {
    font-family: var(--nm-font-mono);
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(15, 15, 15, 0.42);
    margin-bottom: 10px;
  }
  .nm-widget-shot__label {
    font-size: 12px;
    font-weight: 600;
    color: rgba(15, 15, 15, 0.72);
    margin-bottom: 8px;
  }
  .nm-widget-shot__field {
    height: 38px;
    border-radius: 9px;
    background: rgba(15, 15, 15, 0.06);
    margin-bottom: 12px;
    border: 1px solid rgba(15, 15, 15, 0.06);
  }
  .nm-widget-shot__btn {
    display: block;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    padding: 11px 14px;
    border-radius: 9px;
    color: #fff;
  }
  .nm-art-1 .nm-widget-shot__btn { background: #003baf; color: #fff; }
  .nm-art-2 .nm-widget-shot__btn { background: #5fd0a6; color: #0a1f18; }
  .nm-art-3 .nm-widget-shot__btn { background: #9b26f0; color: #fff; }
  .nm-art-4 .nm-widget-shot__btn { background: #ee442e; color: #fff; }

  .nm-card-badge {
    position: absolute;
    top: 14px; left: 14px;
    padding: 5px 10px;
    border-radius: 999px;
    font-family: var(--nm-font-mono);
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    backdrop-filter: blur(6px);
  }
  .nm-badge-sold { background: rgba(0, 59, 175, 0.14); color: #003baf; }
  .nm-badge-preorder { background: rgba(95, 208, 166, 0.22); color: #0d5c45; }
  .nm-badge-wishlist { background: rgba(155, 38, 240, 0.14); color: #9b26f0; }
  .nm-badge-low { background: rgba(238, 68, 46, 0.14); color: #ee442e; }

  .nm-card-body {
    padding: 22px;
    display: flex; flex-direction: column; flex: 1;
  }
  .nm-card-title { font-weight: 600; font-size: 17px; margin-bottom: 6px; line-height: 1.3; }
  .nm-card-sub { font-size: 14px; color: rgba(15,15,15,0.6); margin-bottom: 18px; flex: 1; line-height: 1.5; }
  .nm-card-foot {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 14px; border-top: 1px solid var(--nm-line);
  }
  .nm-card-price { font-family: var(--nm-font-mono); font-size: 13px; color: rgba(15,15,15,0.7); }
  .nm-card-cta { color: var(--nm-blue); font-weight: 600; font-size: 14px; text-decoration: none; }
  .nm-card-cta:hover { text-decoration: underline; }

  /* ====== TESTIMONIALS ====== */
  .nm-test {
    background: var(--nm-paper);
    padding: 96px 24px;
  }
  .nm-test-head { margin-bottom: 12px; }
  .nm-test-head h2 {
    font-family: var(--nm-font-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -0.02em;
    line-height: 1.12;
  }
  .nm-test-sub {
    font-size: 18px;
    color: rgba(15, 15, 15, 0.55);
    max-width: 560px;
    margin: 22px 0 36px;
    line-height: 1.65;
  }
  .nm-quote-kw {
    font-weight: 600;
    color: var(--nm-blue);
    background: linear-gradient(180deg, transparent 58%, rgba(0, 59, 175, 0.14) 58%);
  }
  .nm-test-featured-wrap {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-bottom: 32px;
  }
  .nm-test-featured {
    background: linear-gradient(135deg, rgba(0, 59, 175, 0.06), rgba(110, 139, 255, 0.1));
    border: 1px solid var(--nm-line);
    border-radius: var(--nm-radius-lg);
    padding: 28px 32px;
    margin-bottom: 28px;
    max-width: 720px;
  }
  .nm-test-featured--fullbleed {
    max-width: none;
    margin: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
    padding: clamp(36px, 6vw, 72px) clamp(24px, 5vw, 64px);
    min-height: min(52vw, 420px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-color: rgba(0, 59, 175, 0.05);
    background-image: linear-gradient(
      135deg,
      rgba(10, 10, 18, 0.78) 0%,
      rgba(10, 10, 18, 0.42) 45%,
      rgba(0, 59, 175, 0.12) 100%
    );
    background-size: cover;
    background-position: center;
  }
  .nm-test-featured--fullbleed.nm-test-featured--has-photo {
    background-image: linear-gradient(
        135deg,
        rgba(10, 10, 18, 0.78) 0%,
        rgba(10, 10, 18, 0.42) 45%,
        rgba(0, 59, 175, 0.12) 100%
      ),
      var(--nm-story-photo);
    background-size: cover, cover;
    background-position: center, center;
  }
  .nm-test-featured--fullbleed .nm-test-featured__label,
  .nm-test-featured--fullbleed .nm-test-featured__title {
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }
  .nm-test-featured--fullbleed .nm-test-featured__story {
    color: rgba(255, 255, 255, 0.92);
    max-width: min(720px, 100%);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
  }
  .nm-test-featured--fullbleed .nm-quote-kw {
    color: #fff;
    background: linear-gradient(180deg, transparent 58%, rgba(255, 255, 255, 0.22) 58%);
  }
  .nm-test-featured__label {
    font-family: var(--nm-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--nm-blue);
    margin-bottom: 10px;
  }
  .nm-test-featured__title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .nm-test-featured__story {
    font-size: 16px;
    line-height: 1.55;
    color: rgba(15, 15, 15, 0.78);
    margin: 0;
  }
  .nm-test-disclaimer { font-family: var(--nm-font-mono); font-size: 11px; color: rgba(15,15,15,0.45); margin-bottom: 40px; }
  .nm-test-disclaimer a { color: var(--nm-blue); }
  .nm-test-scroll {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: min(420px, 85vw);
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 16px;
    scrollbar-width: thin;
  }
  .nm-test-scroll::-webkit-scrollbar { height: 6px; }
  .nm-test-scroll::-webkit-scrollbar-thumb { background: var(--nm-line); border-radius: 3px; }
  .nm-test-card {
    background: var(--nm-surface);
    border-radius: var(--nm-radius-lg);
    padding: 24px 26px;
    scroll-snap-align: start;
    display: flex; flex-direction: column;
    min-height: auto;
    aspect-ratio: 5 / 3;
    max-height: 280px;
  }
  .nm-test-tag {
    font-family: var(--nm-font-mono);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--nm-blue);
    margin-bottom: 16px;
  }
  .nm-test-quote {
    font-size: 15px;
    line-height: 1.5;
    flex: 1;
    margin-bottom: 16px;
    color: var(--nm-ink);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 7;
    overflow: hidden;
  }
  .nm-test-author { font-size: 13px; color: rgba(15,15,15,0.55); }

  /* ====== HOW IT WORKS ====== */
  .nm-how {
    background: var(--nm-paper);
    padding: 96px 24px;
    border-top: 1px solid var(--nm-line);
  }
  .nm-how-head { text-align: center; margin-bottom: 64px; }
  .nm-how-head h2 {
    font-family: var(--nm-font-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -0.02em;
  }
  .nm-how-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 28px; }
  .nm-step-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(0, 59, 175, 0.08);
    color: var(--nm-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .nm-step-icon svg {
    width: 22px;
    height: 22px;
  }
  .nm-step-num {
    width: 40px; height: 40px;
    background: var(--nm-blue); color: #fff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--nm-font-mono);
    font-weight: 700; font-size: 14px;
    margin-bottom: 20px;
  }
  .nm-step h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .nm-step p { font-size: 14px; color: rgba(15,15,15,0.6); line-height: 1.55; }
  .nm-how-cta { text-align: center; margin-top: 56px; }

  /* ====== NOTIFY ME! ASSIST ====== */
  .nm-assist {
    background: var(--nm-navy);
    color: #fff;
    padding: 96px 24px;
  }
  .nm-assist-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 40px;
  }
  .nm-assist p.nm-eyebrow { color: #93c5fd; margin-bottom: 12px; }
  .nm-demo .nm-assist h2 {
    font-family: var(--nm-font-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    color: #fff !important;
  }
  .nm-assist-intro {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.55;
    margin: 0;
  }
  .nm-assist-rows {
    max-width: 1100px;
    margin: 0 auto 40px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--nm-radius-lg);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .nm-assist-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    padding: 24px 22px;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: none;
  }
  .nm-assist-row:last-child { border-right: none; }
  .nm-assist-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(147, 197, 253, 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #93c5fd;
    flex-shrink: 0;
  }
  .nm-assist-icon svg {
    width: 22px;
    height: 22px;
  }
  .nm-assist-row h3 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 6px;
    color: #fff;
  }
  .nm-assist-row p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.66);
    line-height: 1.55;
    margin: 0;
  }
  .nm-assist-cta { text-align: center; }

  /* ====== FINAL CTA ====== */
  .nm-final {
    background: var(--nm-blue);
    color: #fff;
    padding: 140px 24px;
    text-align: center;
  }
  .nm-demo .nm-final h2 {
    font-family: var(--nm-font-display);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 auto 40px;
    max-width: 1000px;
    color: #fff !important;
  }
  .nm-final h2 .nm-grad-light {
    background: linear-gradient(90deg, #fff, #BFD0FF);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-style: italic;
  }
  .nm-final .nm-btn { padding: 20px 40px; font-size: 17px; }

  /* ====== Responsive ====== */
  @media (max-width: 1024px) {
    .nm-how-grid { grid-template-columns: repeat(3, 1fr); gap: 32px; }
    .nm-test-scroll { grid-auto-columns: min(360px, 82vw); }
    .nm-assist-rows {
      grid-template-columns: 1fr;
    }
    .nm-assist-row {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      flex-direction: row;
      align-items: flex-start;
    }
    .nm-assist-row:last-child {
      border-bottom: none;
    }
  }
  @media (max-width: 768px) {
    .nm-hero { padding: 64px 20px 72px; min-height: min(92vh, 780px); }
    .nm-hero .nm-cta-row { margin-top: 44px; }
    .nm-products, .nm-logos, .nm-test, .nm-how, .nm-assist { padding: 72px 20px; }
    .nm-logos { padding-top: 36px; padding-bottom: 28px; }
    .nm-final { padding: 96px 20px; }
    .nm-grid { grid-template-columns: 1fr; }
    .nm-how-grid { grid-template-columns: 1fr; gap: 32px; }
    .nm-assist-row { grid-template-columns: 44px 1fr; gap: 16px; padding: 20px 18px; }
    .nm-test-scroll { grid-auto-columns: min(300px, 88vw); }
    .nm-test-card {
      aspect-ratio: auto;
      max-height: none;
    }
    .nm-test-quote {
      -webkit-line-clamp: 8;
    }
  }
</style>

