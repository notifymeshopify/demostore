<script>
  (function () {
    var v = document.getElementById('nm-hero-video');
    if (!v) return;
    function heroPlay() {
      v.muted = true;
      v.defaultMuted = true;
      v.setAttribute('muted', '');
      var p = v.play();
      if (p && typeof p.catch === 'function') {
        p.catch(function () {});
      }
    }
    heroPlay();
    document.addEventListener('visibilitychange', function () {
      if (!document.hidden) heroPlay();
    });
    function unlockOnce() {
      heroPlay();
    }
    ['pointerdown', 'keydown', 'touchstart'].forEach(function (type) {
      document.addEventListener(type, unlockOnce, { capture: true, passive: true, once: true });
    });
  })();
</script>

