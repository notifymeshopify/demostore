{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  {% if section.settings.section_anchor_id != blank %}
    id="{{ section.settings.section_anchor_id | escape }}"
  {% endif %}
  class="nm-product-grid section-{{ section.id }}-padding"
  {{ section.shopify_attributes }}
>
  <div class="page-width">
    {%- if section.settings.show_intro -%}
      <div class="nm-product-grid__intro-wrap nm-section-intro">
        {%- if section.settings.intro_kicker != blank -%}
          <p class="nm-section-intro__kicker nm-display">{{ section.settings.intro_kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.intro_subtitle != blank -%}
          <p class="nm-section-intro__sub">{{ section.settings.intro_subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="nm-product-grid__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign st = block.settings.stock_state
          assign badge_label = block.settings.badge_override
          if badge_label == blank
            case st
              when 'sold_out'
                assign badge_label = 'SOLD OUT'
              when 'preorder'
                assign badge_label = 'PREORDER'
              when 'in_stock'
                assign badge_label = 'IN STOCK'
              when 'low_stock'
                assign badge_label = 'LOW STOCK'
              when 'coming_soon'
                assign badge_label = 'COMING SOON'
              else
                assign badge_label = 'FEATURE'
            endcase
          endif
        -%}
        <article class="nm-product-card nm-stock--{{ st }}" {{ block.shopify_attributes }}>
          <div class="nm-product-card__media">
            <span class="nm-product-card__badge">{{ badge_label | escape }}</span>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  widths: '165, 360, 535, 750, 900',
                  sizes: '(min-width: 1200px) 22vw, (min-width: 750px) 45vw, 90vw',
                  alt: block.settings.image.alt | default: block.settings.title | escape
              }}
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="nm-product-card__body">
            <div class="nm-product-card__title-row">
              <h3 class="nm-product-card__title">{{ block.settings.title | escape }}</h3>
              {%- if block.settings.price_label != blank -%}
                <span class="nm-product-card__price">{{ block.settings.price_label | escape }}</span>
              {%- endif -%}
            </div>
            {%- if block.settings.subtitle != blank -%}
              <p class="nm-product-card__subtitle">{{ block.settings.subtitle | escape }}</p>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <a class="nm-product-card__cta" href="{{ block.settings.cta_url }}">{{ block.settings.cta_label | escape }}</a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>

    <div class="nm-product-grid__links">
      {%- if section.settings.link_compare_label != blank -%}
        <a href="{{ section.settings.link_compare_url }}">{{ section.settings.link_compare_label | escape }}</a>
      {%- endif -%}
      {%- if section.settings.link_all_label != blank -%}
        <a href="{{ section.settings.link_all_url }}">{{ section.settings.link_all_label | escape }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "NM product grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section HTML id (for anchor links)",
      "default": "nm-product-grid"
    },
    {
      "type": "checkbox",
      "id": "show_intro",
      "label": "Show intro lines above grid",
      "default": true
    },
    {
      "type": "text",
      "id": "intro_kicker",
      "label": "Intro title",
      "default": "Notify Me! essentials."
    },
    {
      "type": "text",
      "id": "intro_subtitle",
      "label": "Intro subtitle",
      "default": "Six features. One app. Zero lost sales."
    },
    {
      "type": "text",
      "id": "link_compare_label",
      "label": "Footer link A label",
      "default": "Compare features ↗"
    },
    {
      "type": "url",
      "id": "link_compare_url",
      "label": "Footer link A URL",
      "default": "/pages/compare"
    },
    {
      "type": "text",
      "id": "link_all_label",
      "label": "Footer link B label",
      "default": "View all features →"
    },
    {
      "type": "url",
      "id": "link_all_url",
      "label": "Footer link B URL",
      "default": "/collections/all"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Feature card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shopify's Best Back-in-Stock App"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Capture demand on every sold-out variant."
        },
        {
          "type": "text",
          "id": "price_label",
          "label": "Price label",
          "default": "$0.00/mo"
        },
        {
          "type": "select",
          "id": "stock_state",
          "label": "Stock state",
          "options": [
            { "value": "sold_out", "label": "Sold out" },
            { "value": "preorder", "label": "Preorder" },
            { "value": "in_stock", "label": "In stock" },
            { "value": "low_stock", "label": "Low stock" },
            { "value": "coming_soon", "label": "Coming soon" }
          ],
          "default": "sold_out"
        },
        {
          "type": "text",
          "id": "badge_override",
          "label": "Badge override (optional)"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Try it →"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NM product grid",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "title": "Shopify's Best Back-in-Stock App",
            "subtitle": "Triggers BIS widget on PDP.",
            "price_label": "$0.00/mo",
            "stock_state": "sold_out",
            "cta_url": "/products/shopify-s-best-back-in-stock-app"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Shopify's Best Preorder App",
            "subtitle": "Triggers preorder widget.",
            "price_label": "$0.00/mo",
            "stock_state": "preorder",
            "cta_url": "/products/shopify-s-best-preorder-app"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Shopify's Best Wishlist App",
            "subtitle": "Wishlist heart on PDP.",
            "price_label": "$0.00/mo",
            "stock_state": "in_stock",
            "cta_url": "/products/shopify-s-best-wishlist-app"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Shopify's Best Low-Stock Alert App",
            "subtitle": "Demos FOMO/urgency bar.",
            "price_label": "$0.00/mo",
            "stock_state": "low_stock",
            "cta_url": "/products/shopify-s-best-low-stock-alert-app"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Notify Me! AI for Restock Decisions",
            "subtitle": "Demos preorder w/ launch date.",
            "price_label": "$0.00/mo",
            "stock_state": "coming_soon",
            "cta_url": "/products/notify-me-ai-for-restock-decisions"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Multi-Language Widget Bundle",
            "subtitle": "Demos language picker.",
            "price_label": "$0.00/mo",
            "stock_state": "in_stock",
            "cta_url": "/products/multi-language-widget-bundle"
          }
        }
      ]
    }
  ]
}
{% endschema %}
