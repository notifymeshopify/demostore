{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nm-testimonials section-{{ section.id }}-padding nm-body-font color-{{ section.settings.color_scheme }} gradient" {{ section.shopify_attributes }}>
  <div class="page-width">
    <p class="nm-testimonials__disclaimer rte">{{ section.settings.disclaimer }}</p>
    {%- if section.settings.heading != blank -%}
      <h2 class="nm-section-intro__kicker nm-display" style="text-align: center; margin-bottom: 2rem;">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    <div class="nm-testimonials__arrows">
      <button type="button" class="nm-testimonials__arrow" data-nm-t-prev aria-label="{{ section.settings.prev_label | escape }}">←</button>
      <button type="button" class="nm-testimonials__arrow" data-nm-t-next aria-label="{{ section.settings.next_label | escape }}">→</button>
    </div>
    <div class="nm-testimonials__viewport" data-nm-testimonials-view>
      <div class="nm-testimonials__track" data-nm-t-track>
        {%- for block in section.blocks -%}
          <article class="nm-testimonial-card" {{ block.shopify_attributes }}>
            <p class="nm-testimonial-card__tag">{{ block.settings.tag | escape }}</p>
            <p class="nm-testimonial-card__quote">{{ block.settings.quote | escape }}</p>
            <p class="nm-testimonial-card__author">{{ block.settings.author | escape }}</p>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var view = root.querySelector('[data-nm-testimonials-view]');
    var prev = root.querySelector('[data-nm-t-prev]');
    var next = root.querySelector('[data-nm-t-next]');
    if (!view || !prev || !next) return;
    var amount = Math.min(view.clientWidth * 0.34, 420);
    prev.addEventListener('click', function () {
      view.scrollBy({ left: -amount, behavior: 'smooth' });
    });
    next.addEventListener('click', function () {
      view.scrollBy({ left: amount, behavior: 'smooth' });
    });
  });
</script>

{% schema %}
{
  "name": "NM testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Disclaimer",
