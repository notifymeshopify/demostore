{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .nm-value-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nm-value nm-value-{{ section.id }} section-{{ section.id }}-padding nm-body-font" {{ section.shopify_attributes }}>
  <div class="page-width" style="max-width: 72rem;">
    <h2 class="nm-section-intro__kicker nm-display" style="margin-bottom: 1rem;">{{ section.settings.heading | escape }}</h2>
    <div class="nm-pitch__body rte" style="margin-bottom: 2rem;">{{ section.settings.intro }}</div>
    <ul class="nm-value__list">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
      {%- endfor -%}
    </ul>
    {%- if section.settings.cta_label != blank -%}
      <div style="margin-top: 2.5rem;">
        <a class="nm-button-primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NM value props",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Try Notify Me! risk-free."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Install in 5 minutes. Cancel in one click. Keep the recovered revenue regardless.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Install free →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "✅ Free 14-day trial — no credit card"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NM value props",
      "blocks": [
        {
          "type": "bullet",
          "settings": {
            "text": "✅ Free 14-day trial — no credit card"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "✅ Free 1:1 onboarding call"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "✅ 24/7 support, average response: 11 minutes"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "✅ GDPR + CCPA compliant"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "text": "✅ Works with 50+ Shopify themes out of the box"
          }
        }
      ]
    }
  ]
}
{% endschema %}
