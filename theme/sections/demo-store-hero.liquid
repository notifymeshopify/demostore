{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .nm-hero-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nm-hero nm-hero-{{ section.id }} section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  <div class="page-width">
    <div class="nm-hero__grid">
      <div class="nm-hero__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="nm-hero__eyebrow nm-mono-label">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="nm-hero__heading nm-display">
          {{ section.settings.headline_before | escape }}
          {% if section.settings.headline_highlight != blank %}
            <span class="nm-grad">{{ section.settings.headline_highlight | escape }}</span>
          {% endif %}
          {% if section.settings.headline_after != blank %}
            {{ section.settings.headline_after | escape }}
          {% endif %}
        </h2>
        {%- if section.settings.subhead != blank -%}
          <div class="nm-hero__subhead rte">{{ section.settings.subhead }}</div>
        {%- endif -%}
        <div class="nm-hero__actions">
          {%- if section.settings.primary_label != blank -%}
            <a class="nm-button-primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label | escape }}</a>
          {%- endif -%}
          {%- if section.settings.secondary_label != blank -%}
            <a class="nm-button-secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
      <div class="nm-hero__media">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1600
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              widths: '375, 550, 750, 900, 1100, 1400, 1600',
              sizes: '(min-width: 990px) 40vw, 100vw',
              alt: section.settings.hero_image.alt | escape
          }}
        {%- else -%}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'nm-placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NM demo hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (right)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "NOTIFY ME! DEMO STORE"
    },
    {
      "type": "text",
      "id": "headline_before",
      "label": "Headline (before gradient)",
      "default": "For the merchant who's tired of watching "
    },
    {
      "type": "text",
      "id": "headline_highlight",
      "label": "Headline (gradient)",
      "default": "shoppers leave empty-handed."
    },
    {
      "type": "text",
      "id": "headline_after",
      "label": "Headline (after gradient)",
      "default": ""
    },
    {
      "type": "richtext",
      "id": "subhead",
      "label": "Subhead",
      "default": "<p>Give them the gift of a back-in-stock alert, a preorder option, or a saved wishlist. Save the sale either way.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary CTA label",
      "default": "Install Notify Me! — free →"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary CTA link",
      "default": "https://apps.shopify.com/preorder-back-in-stock"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary CTA label",
      "default": "Tour this demo store ↓"
    },
    {
      "type": "text",
      "id": "secondary_link",
      "label": "Secondary CTA link",
      "default": "#nm-product-grid",
      "info": "Use #nm-product-grid to scroll to the product grid."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "presets": [{ "name": "NM demo hero" }]
}
{% endschema %}
