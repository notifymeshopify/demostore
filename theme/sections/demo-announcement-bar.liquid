{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bg = section.settings.background_color | default: '#0F0F0F'
  assign fg = section.settings.text_color | default: '#FFFFFF'
-%}

<div
  class="nm-announcement nm-body-font color-{{ section.settings.color_scheme }}"
  style="background-color: {{ bg }}; color: {{ fg }};"
  data-nm-announcement
  data-nm-interval="{{ section.settings.rotate_interval | times: 1000 }}"
  {{ section.shopify_attributes }}
>
  <div class="nm-announcement__track page-width">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <p
          class="nm-announcement__slide"
          {% if forloop.first == false %}
            hidden
          {% endif %}
          {{ block.shopify_attributes }}
        >
          {{ block.settings.message }}
        </p>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('[data-nm-announcement]');
    if (!root) return;
    var slides = root.querySelectorAll('.nm-announcement__slide');
    if (slides.length < 2) return;
    var ms = parseInt(root.getAttribute('data-nm-interval'), 10) || 5000;
    var i = 0;
    setInterval(function () {
      slides[i].hidden = true;
      i = (i + 1) % slides.length;
      slides[i].hidden = false;
    }, ms);
  })();
</script>

{% schema %}
{
  "name": "NM announcement bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0F0F0F"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "rotate_interval",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Rotate interval",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "textarea",
          "id": "message",
          "label": "Message",
          "default": "🔔 Free 14-day trial — no credit card, no commitment."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NM announcement bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "message": "🔔 Free 14-day trial — no credit card, no commitment."
          }
        },
        {
          "type": "message",
          "settings": {
            "message": "📦 Join 10,000+ Shopify merchants recovering lost sales."
          }
        },
        {
          "type": "message",
          "settings": {
            "message": "⚡ 5-minute install. Works on every theme."
          }
        }
      ]
    }
  ]
}
{% endschema %}
