{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nm-how section-{{ section.id }}-padding nm-body-font color-{{ section.settings.color_scheme }} gradient" {{ section.shopify_attributes }}>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="nm-section-intro__kicker nm-display" style="text-align: center; margin-bottom: 3rem;">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    <div class="nm-how__grid">
      {%- for block in section.blocks -%}
        <div class="nm-how__pillar" {{ block.shopify_attributes }}>
          <div class="nm-how__num">{{ block.settings.step_number | escape }}</div>
          <div class="nm-how__icon">
            {% render 'demo-store-feature-icon', icon: block.settings.icon %}
          </div>
          <h3 class="nm-how__title">{{ block.settings.title | escape }}</h3>
          <p class="nm-how__text">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
    <div style="text-align: center; margin-top: 3rem;">
      {%- if section.settings.cta_label != blank -%}
        <a class="nm-button-primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NM how it works",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Notify Me! works"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Install Notify Me! →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "notify", "label": "Bell / notify" },
            { "value": "preorder", "label": "Preorder" },
            { "value": "wishlist", "label": "Wishlist" },
            { "value": "capture", "label": "Capture" },
            { "value": "chart", "label": "Chart" }
          ],
          "default": "capture"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Capture demand"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Body",
          "default": "Shoppers tap \"Notify Me\" on any out-of-stock variant. Email captured, intent logged."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NM how it works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "1",
            "icon": "capture",
            "title": "Capture demand",
            "text": "Shoppers tap \"Notify Me\" on any out-of-stock variant. Email captured, intent logged."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "2",
            "icon": "notify",
            "title": "Notify on restock",
            "text": "Email, SMS, or push fires automatically the moment inventory returns."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "3",
            "icon": "preorder",
            "title": "Convert preorders",
            "text": "Sell what you don't have yet. Deposits or full payment, your call."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "4",
            "icon": "wishlist",
            "title": "Save wishlists",
            "text": "Logged-in shoppers save items. You see exactly what's wanted, by who, at what size."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "5",
            "icon": "chart",
            "title": "Recover lost revenue",
            "text": "Dashboard shows recovered sales, top wanted SKUs, and unfulfilled demand."
          }
        }
      ]
    }
  ]
}
{% endschema %}
