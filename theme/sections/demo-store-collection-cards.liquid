{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <div class="title-wrapper title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2 class="title inline-richtext {{ section.settings.heading_size }} center">
          {{ section.settings.title | escape }}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <div class="center rte">{{ section.settings.subtitle }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="demo-store-collection-cards__grid{% if section.settings.title != blank %} element-margin-top{% endif %}">
      {%- for block in section.blocks -%}
        {%- assign coll = block.settings.collection -%}
        <a
          class="demo-store-collection-card"
          href="{% if coll != blank %}{{ coll.url }}{% else %}#{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="demo-store-collection-card__media">
            {%- if coll != blank and coll.featured_image != blank -%}
              {{
                coll.featured_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '165, 360, 535, 750, 900, 1100',
                  sizes: '(min-width: 990px) calc((100vw - 10rem) / 3), (min-width: 750px) calc((100vw - 6rem) / 2), calc(100vw - 3rem)'
              }}
            {%- else -%}
              {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="demo-store-collection-card__body">
            <p class="demo-store-collection-card__label h4">
              {%- if block.settings.custom_title != blank -%}
                {{ block.settings.custom_title | escape }}
              {%- elsif coll != blank -%}
                {{ coll.title | escape }}
              {%- else -%}
                {{ 'onboarding.collection_title' | t }}
              {%- endif -%}
            </p>
            {%- if block.settings.hint != blank -%}
              <p class="demo-store-collection-card__hint">{{ block.settings.hint | escape }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Demo collection cards",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop stories built for your app"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subheading",
      "default": "<p>Assign each tile to a collection (preorder, low stock, or favorites) in the theme editor.</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Overrides collection title when set."
        },
        {
          "type": "text",
          "id": "hint",
          "label": "Short line under title",
          "default": "Try preorder & alerts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Demo collection cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "hint": "Preorder & selling plans"
          }
        },
        {
          "type": "card",
          "settings": {
            "hint": "Sold out → notify me"
          }
        },
        {
          "type": "card",
          "settings": {
            "hint": "Wishlist-friendly picks"
          }
        }
      ]
    }
  ]
}
{% endschema %}
