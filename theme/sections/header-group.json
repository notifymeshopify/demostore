{
  "name": "t:sections.header.name",
  "type": "header",
  "sections": {
    "nm-announcement": {
      "type": "demo-announcement-bar",
      "blocks": {
        "m1": {
          "type": "message",
          "settings": {
            "message": "🔔 Free Trial — no credit card, no commitment."
          }
        },
        "m2": {
          "type": "message",
          "settings": {
            "message": "📦 Join 10,000+ Shopify merchants recovering lost sales."
          }
        },
        "m3": {
          "type": "message",
          "settings": {
            "message": "⚡ 5-minute install. Works on every theme."
          }
        }
      },
      "block_order": ["m1", "m2", "m3"],
      "settings": {
        "background_color": "#0F0F0F",
        "text_color": "#FFFFFF",
        "rotate_interval": 5,
        "color_scheme": "scheme-1"
      }
    },
    "header": {
      "type": "header",
      "settings": {
        "enable_nm_demo_header": true,
        "nm_demo_badge_text": "Demo Store",
        "nm_nav_aria_label": "Primary navigation",
        "nm_link_products_label": "Products",
        "nm_link_how_label": "How it works",
        "nm_install_app_label": "Install App",
        "nm_install_app_url": "https://apps.shopify.com/preorder-back-in-stock",
        "color_scheme": "scheme-1",
        "logo_position": "middle-left",
        "menu": "main-menu",
        "menu_type_desktop": "dropdown",
        "sticky_header_type": "on-scroll-up",
        "show_line_separator": true,
        "enable_country_selector": true,
        "enable_language_selector": true,
        "mobile_logo_position": "center",
        "margin_bottom": 0,
        "padding_top": 16,
        "padding_bottom": 16
      }
    }
  },
  "order": ["nm-announcement", "header"]
}
