{%- liquid
  assign out = section.settings.default_text
  for block in section.blocks
    if block.settings.product_handle != blank and product.handle == block.settings.product_handle
      assign out = block.settings.callout_text
      break
    endif
  endfor
-%}

{%- if out != blank -%}
  {{ 'section-demo-store.css' | asset_url | stylesheet_tag }}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}
  <aside class="nm-pdp-callout section-{{ section.id }}-padding page-width nm-body-font" {{ section.shopify_attributes }}>
    <div class="rte">{{ out }}</div>
  </aside>
{%- endif -%}

{% schema %}
{
  "name": "NM PDP feature callout",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "richtext",
      "id": "default_text",
      "label": "Default callout",
      "default": "<p>This demo product showcases Notify Me! on your storefront.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "override",
      "name": "Per-product callout",
      "settings": [
        {
          "type": "text",
          "id": "product_handle",
          "label": "Product handle",
          "info": "Must match the product URL handle exactly."
        },
        {
          "type": "richtext",
          "id": "callout_text",
          "label": "Callout text",
          "default": "<p>You're on the back-in-stock demo. The bell button above is live — try it.</p>"
        }
      ]
    }
  ],
  "presets": [{ "name": "NM PDP feature callout" }]
}
{% endschema %}
