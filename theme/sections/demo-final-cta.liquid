{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .nm-final-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nm-final-cta nm-final-{{ section.id }} section-{{ section.id }}-padding nm-body-font" {{ section.shopify_attributes }}>
  <div class="page-width">
    <h2 class="nm-final-cta__headline nm-display">
      {{ section.settings.headline_before | escape }}
      <span class="nm-grad">{{ section.settings.headline_highlight | escape }}</span>
      {{ section.settings.headline_after | escape }}
    </h2>
    {%- if section.settings.cta_label != blank -%}
      <a class="nm-button-primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NM final CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#003BAF"
    },
    {
      "type": "text",
      "id": "headline_before",
      "label": "Headline (before gradient)",
      "default": "Join "
    },
    {
      "type": "text",
      "id": "headline_highlight",
      "label": "Headline (gradient)",
      "default": "10,000+"
    },
    {
      "type": "text",
      "id": "headline_after",
      "label": "Headline (after gradient)",
      "default": " Shopify merchants recovering lost sales."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Install Free →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 220,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 220,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 120
    }
  ],
  "presets": [{ "name": "NM final CTA" }]
}
{% endschema %}
