{{ 'section-demo-store.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <div class="title-wrapper title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2 class="title inline-richtext {{ section.settings.heading_size }} center">
          {{ section.settings.title | escape }}
        </h2>
      </div>
    {%- endif -%}

    <div class="demo-store-features__grid{% if section.settings.title != blank %} element-margin-top{% endif %}">
      {%- for block in section.blocks -%}
        <div
          class="demo-store-feature"
          {{ block.shopify_attributes }}
        >
          <div class="demo-store-feature__icon" aria-hidden="true">
            {% render 'demo-store-feature-icon', icon: block.settings.icon %}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="demo-store-feature__title h4">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="demo-store-feature__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <a
              class="link underlined-link"
              {% if block.settings.link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ block.settings.link }}"
              {% endif %}
            >
              {{ block.settings.link_label | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Demo store features",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How shoppers use this store"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "preorder", "label": "Preorder" },
            { "value": "notify", "label": "Back in stock" },
            { "value": "wishlist", "label": "Wishlist" }
          ],
          "default": "preorder"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Preorder"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Reserve products before they arrive. Your app can replace the standard purchase flow on the product form.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "View preorder picks"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Demo store features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "preorder",
            "title": "Preorder",
            "text": "<p>Reserve products before they arrive. Pair this section with preorder rules in your app.</p>",
            "link_label": "Shop preorder"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "notify",
            "title": "Back in stock",
            "text": "<p>Let visitors subscribe when an item is sold out. Perfect for testing email and SMS alerts.</p>",
            "link_label": "See restocks"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "wishlist",
            "title": "Wishlist",
            "text": "<p>Save favorites for later and drive return visits — showcase your wishlist experience across collection and product pages.</p>",
            "link_label": "Browse all"
          }
        }
      ]
    }
  ]
}
{% endschema %}
